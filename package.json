    "@types/better-sqlite3": "^7.6.13",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
