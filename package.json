{
  "name": "moji-docs",
  "version": "1.0.1",
  "description": "MojiDocs - Markdown Wiki 桌面应用",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
